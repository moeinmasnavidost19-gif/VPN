# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# BREVO_API_KEY: Required for real email OTP sending.
# Retrieve from brevo.com -> SMTP & API Keys.
BREVO_API_KEY=YOUR_BREVO_API_KEY

# RESEND_API_KEY: Alternative required for real email OTP sending (highly recommended).
# Retrieve from resend.com -> API Keys.
RESEND_API_KEY=YOUR_RESEND_API_KEY

